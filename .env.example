# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aviary_manager

# ─── Storage (Tigris / S3-compatible) ─────────────────────────────────────────
TIGRIS_ENDPOINT_URL=
TIGRIS_ACCESS_KEY_ID=
TIGRIS_SECRET_ACCESS_KEY=
TIGRIS_BUCKET_NAME=

# ─── OAuth (legacy Manus) ─────────────────────────────────────────────────────
OWNER_OPEN_ID=
OWNER_EMAIL=

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── SMM Companion App ────────────────────────────────────────────────────────
# Shared secret for the /api/smm/* read-only endpoints consumed by the SMM app.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SMM_API_SECRET=

